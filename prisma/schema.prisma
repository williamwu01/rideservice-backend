generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Customer {
  id              String   @id @default(cuid())
  firstName       String
  lastName        String
  email           String   @unique
  whatsappEnabled Boolean  @default(false)
  phone           String?
  address         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Admin {
  id        String   @id @default(cuid())
  phone     String   @unique
  name      String
  createdAt DateTime @default(now())
}

model PricingConfig {
  id            String    @id @default(cuid())
  name          String    @unique
  baseFare      Float
  perKm         Float
  perMin        Float
  bookingFee    Float
  minimumFare   Float
  airportFee    Float
  lateNightFee  Float
  isActive      Boolean   @default(false)
  effectiveFrom DateTime?
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model PromoCode {
  id          String    @id @default(cuid())
  code        String    @unique
  discount    Float
  maxUses     Int?
  usedCount   Int       @default(0)
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Driver {
  id              String        @id @default(cuid())
  firstName       String
  lastName        String
  email           String        @unique
  phone           String
  carModel        String
  carNameplate    String
  photo           String?
  whatsappEnabled Boolean       @default(true)
  rideRequests    RideRequest[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model ConversationState {
  id               String           @id @default(cuid())
  phone            String           @unique
  step             ConversationStep @default(AWAITING_NAME)
  firstName        String?
  lastName         String?
  pickup           String?
  destination      String?
  pickupTime       String?
  pendingBookingId String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model RideRequest {
  id          String     @id @default(cuid())
  phone       String
  firstName   String
  lastName    String
  pickup      String
  destination String
  pickupTime  String?
  status      RideStatus @default(PENDING)
  driverId      String?
  driver        Driver?    @relation(fields: [driverId], references: [id])
  estimatedFare Float?
  distanceKm    Float?
  durationMin   Int?
  promoCode      String?
  promoDiscount  Float?        @default(0)
  finalFare      Float?
  paypalOrderId  String?
  paymentStatus  PaymentStatus @default(UNPAID)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum ConversationStep {
  AWAITING_NAME
  AWAITING_PICKUP
  AWAITING_DESTINATION
  AWAITING_PICKUP_TIME
  AWAITING_DRIVER_CONFIRMATION
  COMPLETE
}

enum RideStatus {
  AWAITING_ADMIN
  PENDING
  MATCHED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}