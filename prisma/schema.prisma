generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Customer {
  id              String   @id @default(cuid())
  firstName       String
  lastName        String
  email           String   @unique
  whatsappEnabled Boolean  @default(false)
  phone           String?
  address         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Driver {
  id              String        @id @default(cuid())
  firstName       String
  lastName        String
  email           String        @unique
  phone           String
  carModel        String
  carNameplate    String
  photo           String?
  whatsappEnabled Boolean       @default(true)
  isOnline        Boolean       @default(false)
  maxPassengers   Int           @default(4)
  maxLuggage      Int           @default(2)
  latitude        Float?
  longitude       Float?
  rideRequests    RideRequest[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model ConversationState {
  id               String           @id @default(cuid())
  phone            String           @unique
  step             ConversationStep @default(AWAITING_NAME)
  firstName        String?
  lastName         String?
  pickup           String?
  destination      String?
  pickupTime       String?
  passengers       Int?
  luggage          Int?
  pendingBookingId String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model RideRequest {
  id          String     @id @default(cuid())
  phone       String
  firstName   String
  lastName    String
  pickup      String
  destination String
  pickupTime  String?
  passengers        Int        @default(1)
  luggage           Int        @default(0)
  scheduledPickupAt DateTime?
  proposedDriverId  String?
  triedDriverIds    String[]   @default([])
  status            RideStatus @default(PENDING)
  driverId    String?
  driver      Driver?    @relation(fields: [driverId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

enum ConversationStep {
  AWAITING_NAME
  AWAITING_PICKUP
  AWAITING_DESTINATION
  AWAITING_PICKUP_TIME
  AWAITING_PASSENGERS
  AWAITING_LUGGAGE
  AWAITING_DRIVER_CONFIRMATION
  COMPLETE
}

enum RideStatus {
  AWAITING_ADMIN
  SCHEDULED
  PENDING
  MATCHED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}