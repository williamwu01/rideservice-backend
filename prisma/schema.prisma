generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Customer {
  id              String   @id @default(cuid())
  firstName       String
  lastName        String
  email           String   @unique
  whatsappEnabled Boolean  @default(false)
  phone           String?
  address         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Driver {
  id              String        @id @default(cuid())
  firstName       String
  lastName        String
  email           String        @unique
  phone           String
  whatsappEnabled Boolean       @default(true)
  rideRequests    RideRequest[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model ConversationState {
  id          String           @id @default(cuid())
  phone       String           @unique
  step        ConversationStep @default(AWAITING_NAME)
  firstName   String?
  lastName    String?
  pickup      String?
  destination String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model RideRequest {
  id          String     @id @default(cuid())
  phone       String
  firstName   String
  lastName    String
  pickup      String
  destination String
  status      RideStatus @default(PENDING)
  driverId    String?
  driver      Driver?    @relation(fields: [driverId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

enum ConversationStep {
  AWAITING_NAME
  AWAITING_PICKUP
  AWAITING_DESTINATION
  COMPLETE
}

enum RideStatus {
  PENDING
  MATCHED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}